// Diagrama de estructura JSONB para todas las páginas de ROHIGARNEZ
// Importar en diagrams.dbml.io

// Tabla principal de PÁGINAS
Table pages {
  page_id UUID [primary key]
  page_type String [note: "HomePage, ProjectsPage, ServicesPage, TeamPage, ContactPage, AboutPage, BrandsPage, QuotePage, PoolMaterialsPage, etc"]
  page_name String
  created_at Timestamp
  updated_at Timestamp
  data JSONB [note: "Contiene toda la data específica de cada página"]
}

// Tabla de SERVICIOS (usado en múltiples páginas)
Table services {
  service_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  title String
  description Text
  image String
  icon String
  category String [note: "construction, renovation, community, tech"]
  price Decimal [null]
  duration String [null]
  created_at Timestamp
}

// Tabla de CARACTERÍSTICAS
Table features {
  feature_id UUID [primary key]
  service_id UUID [ref: > services.service_id, null]
  page_id UUID [ref: > pages.page_id]
  title String
  description Text
  icon String
  order Integer
  created_at Timestamp
}

// Tabla de PROYECTOS
Table projects {
  project_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  title String
  category String
  description Text
  client String
  location String
  year String
  duration String
  image String
  highlight_id UUID [ref: > highlights.highlight_id, null]
  spec_id UUID [ref: > project_specs.spec_id, null]
  created_at Timestamp
}

// Tabla de DESTACADOS (highlights)
Table highlights {
  highlight_id UUID [primary key]
  project_id UUID [ref: > projects.project_id]
  title String
  order Integer
  created_at Timestamp
}

// Tabla de ESPECIFICACIONES DE PROYECTOS
Table project_specs {
  spec_id UUID [primary key]
  project_id UUID [ref: > projects.project_id]
  vaso String [null]
  revestimiento String [null]
  depuracion String [null]
  dimensiones String [null]
  created_at Timestamp
}

// Tabla de EQUIPO (TeamPage)
Table team_members {
  member_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  name String
  role String
  experience String
  bio Text
  image String
  phone String [null]
  email String [null]
  created_at Timestamp
}

// Tabla de ESPECIALIDADES del equipo
Table specialties {
  specialty_id UUID [primary key]
  member_id UUID [ref: > team_members.member_id]
  specialty String
  created_at Timestamp
}

// Tabla de CERTIFICACIONES del equipo
Table certifications {
  certification_id UUID [primary key]
  member_id UUID [ref: > team_members.member_id]
  certification String
  created_at Timestamp
}

// Tabla de CATEGORÍAS DE SERVICIOS (PoolMaterialsPage)
Table service_categories {
  category_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  title String
  description Text
  icon String
  code String [note: "CHM-01, CLN-02, etc"]
  created_at Timestamp
}

// Tabla de ITEMS por categoría
Table category_items {
  item_id UUID [primary key]
  category_id UUID [ref: > service_categories.category_id]
  item_name String
  order Integer
  created_at Timestamp
}

// Tabla de PAQUETES DE SERVICIOS
Table service_packages {
  package_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  name String
  subtitle String [null]
  price String
  period String [note: "/mes, /anual, etc"]
  description Text
  recommended Boolean
  compliance String [null]
  created_at Timestamp
}

// Tabla de CARACTERÍSTICAS DE PAQUETE
Table package_features {
  feature_id UUID [primary key]
  package_id UUID [ref: > service_packages.package_id]
  feature String
  order Integer
  created_at Timestamp
}

// Tabla de SERVICIOS ESPECIALIZADOS (para socorristas, etc)
Table specialized_services {
  service_id UUID [primary key]
  package_id UUID [ref: > service_packages.package_id, null]
  title String
  description Text
  icon String
  critical Boolean [null]
  created_at Timestamp
}

// Tabla de CONTACTO
Table contact_info {
  contact_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  label String
  value String
  phone String [null]
  email String [null]
  sub_info String [null]
  icon String [null]
  created_at Timestamp
}

// Tabla de UBICACIONES
Table locations {
  location_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  address_line1 String
  address_line2 String [null]
  city String
  country String
  coordinates String [null]
  created_at Timestamp
}

// Tabla de FORMULARIO DE CONTACTO
Table contact_forms {
  form_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  name String
  email String
  phone String [null]
  company String [null]
  service String [null]
  message Text
  submitted_at Timestamp
  status String [note: "pending, sent, responded"]
}

// Tabla de USUARIOS (para páginas dinámicas)
Table users {
  user_id UUID [primary key]
  username String [unique]
  email String [unique]
  role String [note: "admin, client, user"]
  created_at Timestamp
}

// Tabla de DATOS DE USUARIO EN PÁGINAS
Table user_page_data {
  data_id UUID [primary key]
  user_id UUID [ref: > users.user_id]
  page_id UUID [ref: > pages.page_id]
  data JSONB [note: "Datos personalizados del usuario en cada página"]
  created_at Timestamp
  updated_at Timestamp
}

// Tabla de TESTIMONIOS/RESEÑAS
Table testimonials {
  testimonial_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  author String
  role String [null]
  content Text
  rating Integer [note: "1-5 stars"]
  image String [null]
  created_at Timestamp
}

// Tabla de MARCAS/PARTNERS
Table brands {
  brand_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  name String
  logo String
  description Text [null]
  category String [null]
  created_at Timestamp
}

// Tabla de VALORES DE LA EMPRESA
Table company_values {
  value_id UUID [primary key]
  page_id UUID [ref: > pages.page_id]
  title String
  value String
  description Text
  icon String
  order Integer
  created_at Timestamp
}
